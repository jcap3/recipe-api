      "position": 2
    },
    {
      "ingredientName": "Lemon Juice",
      "displayText": "1 tsp lemon juice",
      "quantity": 1,
      "unit": "tsp",
      "preparationNote": null,
      "optionalIngredient": false,
      "position": 3
    }
  ],
  "instructions": [
    {
      "stepNumber": 1,
      "instruction": "Toast the bread.",
      "durationSeconds": 180
    },
    {
      "stepNumber": 2,
